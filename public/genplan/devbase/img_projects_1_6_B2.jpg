<header class="header">
    <div class="container">

        <div class="row-header row">
            <a href="/" class="header__img"><img src="/images/log.svg" alt="DevBase" title="DevBase"></a>
            <div class="u-header-wrapper">
                                    <ul class="u-header-menu">

                                                    <li class="u-header-menu__item">
                                <a class="u-header-link" href="/crm/deal">
                      <span class="u-svg-wrapper">
                        <svg class="icon--house_2 u-header-link__icon" role="presentation">
                          <use xlink:href="#icon-house_2"></use>
                        </svg>
                      </span>
                                    <div class="u-header-link__text">CRM</div>
                                </a>
                            </li>
                                                <li class="u-header-menu__item">
                            <a class="u-header-link" href="/compare">
                      <span class="u-svg-wrapper">
                        <svg class="icon--compare_2 u-header-link__icon" role="presentation">
                          <use xlink:href="#icon-compare_2"></use>
                        </svg>

                        <span id="compare" class="flat-count" style="display:none">0</span>
                      </span>
                                <div class="u-header-link__text">Порівняння</div>
                            </a>
                        </li>
                        <li class="u-header-menu__item">
                            <a class="u-header-link" href="/favorites">
                      <span class="u-svg-wrapper">
                        <svg class="icon--star_2 u-header-link__icon" role="presentation">
                          <use xlink:href="#icon-star_2"></use>
                        </svg>
                        <span id="favorit"  class="flat-count" style="display:none">0</span>
                      </span>
                                <div class="u-header-link__text">Обране</div>
                            </a>
                        </li>
                    </ul>
                
                <!-- SELECT FOR Multiply Currencies -->

                <script>
                    document.body.addEventListener('click', ({ target }) => {
                        if (target.closest('.select-filter__head') === null) return;
                        const selectWrap = target.closest('.select-filter');
                        selectWrap.classList.add('opened');
                        selectWrap.addEventListener('mouseleave', () => selectWrap.classList.remove('opened'), {
                            once: true,
                        })
                    });

                    document.body.addEventListener('click', ({ target }) => {
                        if (target.closest('.select-filter__dropdown-item') === null || target.closest('[data-currency-select]') === null) return;
                        const label = target.closest('.select-filter__dropdown-item');
                        const selectWrap = target.closest('.select-filter');
                        const currentSelectedItem = selectWrap.querySelector('.select-filter__head');
                        currentSelectedItem.dataset.value = label.textContent;
                        const sendData = new FormData();
                        sendData.append('currency', currentSelectedItem.dataset.value.trim())
                        fetch('/filter/currency/', {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            method: 'POST',
                            body: sendData
                        })
                        .then(res => {
                            window.location.reload();
                        })
                    })

                </script>

                <!-- SELECT FOR Multiply Currencies END -->
                

                    <div class="u-header-menu js-u-header-menu">

                                                    <a class="u-header-link color-link--white u-header-menu-btn" href="/registration">
                                <svg class="icon--user_2 u-header-link__icon color-link--white-svg" role="presentation">
                                    <use xlink:href="#icon-user_2"></use>
