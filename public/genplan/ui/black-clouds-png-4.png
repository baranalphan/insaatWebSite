<style>
    .send-error-popup__wrap {
    display: none !important;
}
</style>
<script>
    window.addEventListener('flybyLoading', async function(evt) {
        try {
            const { userAgent } = navigator;
            const { timePlain: load_time, url } = evt.detail;
            const fd = new FormData();
            fd.append('load_time', load_time);
            fd.append('url', url);
            fd.append('user_agent', userAgent);
            const response = await fetch('https://spinhouse-bugtracker.smarto.agency/inc/speed_reports/add.php', {
                method: 'POST',
                body: fd
            });
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            const data = await response.json();
            // console.log(data);
        } catch (error) {
            // console.error('Error:', error);
        }
    });
</script>
